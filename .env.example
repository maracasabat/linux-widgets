# Конфігурація десклета Claude Usage Limits через змінні середовища.
#
# Скопіюйте цей файл у ~/.config/claude-usage-desklet/.env :
#   mkdir -p ~/.config/claude-usage-desklet
#   cp .env.example ~/.config/claude-usage-desklet/.env
#
# Усі змінні необов'язкові. Пріоритет: змінні середовища процесу Cinnamon >
# цей файл > налаштування десклета > типові значення.

# OAuth-токен напряму (тоді credentials.json не читається).
# Увага: токени Claude Code періодично ротуються — статичний токен з часом
# протермінується. Типовий режим (читання з credentials.json) надійніший.
#CLAUDE_OAUTH_TOKEN=sk-ant-oat01-...

# Власний шлях до credentials.json (типово ~/.claude/.credentials.json)
#CLAUDE_CREDS_PATH=~/.claude/.credentials.json

# Власний ендпоінт API використання (рідко потрібно)
#CLAUDE_USAGE_URL=https://api.anthropic.com/api/oauth/usage
